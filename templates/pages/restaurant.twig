{% extends 'base.twig' %}

{% block content %}
<div id="page-content">
  {% include 'sections/header.twig' with {'data': {}} %}
  <main class="restaurant-detail" role="main">
    {% set r = restaurant.restaurant %}

    {% if restaurant.covers is defined and restaurant.covers|length > 0 %}
      <section class="restaurant-detail__item slider-wrap restaurant-intro">
        <div class="swiper-container" id="restaurantSlider" data-settings="{{ {
          loop: true,
          autoplay: { delay: 5000, disableOnInteraction: false },
          pagination: { enabled: true, clickable: true },
          navigation: { enabled: true },
          effect: 'fade',
          speed: 800
        }|json_encode }}">
          <div class="swiper-wrapper">
            {% for cover in restaurant.covers %}
              <div class="swiper-slide">
                <img src="{{ url(cover.src) }}" alt="{{ cover.alt|default(r.name) }}" class="img-responsive" loading="{{ loop.first ? 'eager' : 'lazy' }}">
              </div>
            {% endfor %}
          </div>
          <div class="swiper-pagination"></div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
        </div>

        <div class="restaurant-intro__overlay">
          <div class="container">
            <div class="restaurant-intro__content">
              <h1 class="restaurant-intro__title heading font-1 weight-300 uppercase">{{ r.name }}</h1>

              <div class="restaurant-intro__contacts">
                {% if r.address is defined %}
                  <p class="restaurant-intro__line">{{ r.address.addressLocality }}{% if r.address.streetAddress %}, {{ r.address.streetAddress }}{% endif %}</p>
                {% endif %}
                {% if r.telephone is defined %}
                  <a href="{{ r.telephone.href }}" class="restaurant-intro__line link">{{ r.telephone.title|default(r.telephone.href) }}</a>
                {% endif %}
              </div>

              {% if r.openingHours is defined and r.openingHours|length > 0 %}
                <div class="restaurant-intro__hours">
                  <div class="restaurant-intro__hours-title">
                    <span class="restaurant-intro__hours-icon" aria-hidden="true"></span>
                    <span>Часы работы:</span>
                  </div>
                  {% for h in r.openingHours %}
                    <div class="restaurant-intro__hours-row">{{ h.days }}: {{ h.hours }}</div>
                  {% endfor %}
                </div>
              {% endif %}

              {% if r.breakfastHours is defined and r.breakfastHours|length > 0 %}
                <div class="restaurant-intro__hours">
                  <div class="restaurant-intro__hours-title"><span>Завтрак:</span></div>
                  {% for h in r.breakfastHours %}
                    <div class="restaurant-intro__hours-row">{{ h.days }}: {{ h.hours }}</div>
                  {% endfor %}
                </div>
              {% endif %}

              {% if r.bookingLink is defined or r.menuLink is defined %}
                <div class="restaurant-intro__actions">
                  {% if r.bookingLink is defined and r.bookingLink %}
                    <a href="{{ r.bookingLink }}" target="_blank" rel="noopener noreferrer" class="button button-md button-rounded bg-color-1 color-2 uppercase link">Забронировать</a>
                  {% endif %}
                  {% if r.menuLink is defined and r.menuLink %}
                    <a href="{{ r.menuLink }}" target="_blank" rel="noopener noreferrer" class="button button-md button-rounded outline-color-1 color-1 uppercase link">Меню</a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </section>
    {% endif %}

    <div class="container-md">
      <section class="restaurant-detail__item info-wrap section">
        <div class="section__item heading-wrap">
          {% if restaurant.logos[1] is defined %}
            <div class="section__subitem logo-wrap">
              <img src="{{ url(restaurant.logos[1].src) }}" alt="{{ restaurant.logos[1].alt|default(r.name) }}" class="img-responsive">
            </div>
          {% endif %}
          <div class="section__subitem title-wrap">
            <h1 class="heading font-1 weight-300 uppercase">{{ r.name }}</h1>
            {% if restaurant.desc.short is defined %}
              <p class="desc">{{ restaurant.desc.short }}</p>
            {% endif %}
          </div>
        </div>

        {% if restaurant.tags is defined and restaurant.tags|length > 0 %}
          <div class="section__item tags-wrap">
            {% for tag in restaurant.tags %}
              <span class="button bg-color-6 button-tag button-sm button-rounded nowrap">{{ tag }}</span>
            {% endfor %}
          </div>
        {% endif %}

        {% if restaurant.desc.full is defined %}
          <div class="section__item desc-wrap">
            <p>{{ restaurant.desc.full }}</p>
          </div>
        {% endif %}
      </section>
    </div>

    <div class="container-md">
      <section class="restaurant-detail__item details-wrap section">
        <div class="section__item block-wrap">

          {% if r.address is defined or r.telephone is defined %}
            <div class="section__subitem col-wrap">
              <h2 class="heading weight-400 uppercase">Контакты</h2>
              <div class="mini-table" role="table" aria-label="Контакты">
                {% if r.address is defined %}
                  <div class="mini-table__item" role="row">
                    <span class="mini-table__title uppercase weight-400 color-2" role="cell">Адрес</span>
                    <span class="mini-table__value uppercase" role="cell">{{ r.address.streetAddress|default('') }}{% if r.address.addressLocality %}, {{ r.address.addressLocality }}{% endif %}</span>
                  </div>
                {% endif %}
                {% if r.telephone is defined %}
                  <div class="mini-table__item" role="row">
                    <span class="mini-table__title uppercase weight-400 color-2" role="cell">Телефон</span>
                    <span class="mini-table__value uppercase" role="cell"><a href="{{ r.telephone.href }}" class="link">{{ r.telephone.title|default(r.telephone.href) }}</a></span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}

          {% if r.openingHours is defined and r.openingHours|length > 0 %}
            <div class="section__subitem col-wrap">
              <h2 class="heading weight-400 uppercase">Часы работы</h2>
              <div class="mini-table" role="table" aria-label="Часы работы">
                {% for h in r.openingHours %}
                  <div class="mini-table__item" role="row">
                    <span class="mini-table__title uppercase weight-400 color-2" role="cell">{{ h.days|default('') }}</span>
                    <span class="mini-table__value uppercase" role="cell">{{ h.hours|default('') }}</span>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          {% if r.servesCuisine is defined or r.priceRange is defined %}
            <div class="section__subitem col-wrap">
              <h2 class="heading weight-400 uppercase">Кухня</h2>
              <div class="mini-table" role="table" aria-label="Кухня">
                {% if r.servesCuisine is defined %}
                  <div class="mini-table__item" role="row">
                    <span class="mini-table__title uppercase weight-400 color-2" role="cell">Тип</span>
                    <span class="mini-table__value uppercase" role="cell">{{ r.servesCuisine|join(', ') }}</span>
                  </div>
                {% endif %}
                {% if r.priceRange is defined %}
                  <div class="mini-table__item" role="row">
                    <span class="mini-table__title uppercase weight-400 color-2" role="cell">Цены</span>
                    <span class="mini-table__value uppercase" role="cell">{{ r.priceRange }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}

        </div>
      </section>
    </div>

    {% if r.menuLink is defined or r.hasMap is defined or r.bookingLink is defined %}
      <div class="container-md">
        <div class="restaurant-detail__item buttons-wrap">
          {% if r.bookingLink is defined and r.bookingLink %}
            <a href="{{ r.bookingLink }}" target="_blank" rel="noopener noreferrer" class="button button-sm outline-color-2 button-animated animation-shift uppercase link">Забронировать</a>
          {% endif %}
          {% if r.menuLink is defined and r.menuLink %}
            <a href="{{ r.menuLink }}" target="_blank" rel="noopener noreferrer" class="button button-sm outline-color-2 button-animated animation-shift uppercase link">Меню</a>
          {% endif %}
          {% if r.hasMap is defined and r.hasMap %}
            <a href="{{ r.hasMap }}" target="_blank" rel="noopener noreferrer" class="button button-sm outline-color-2 button-animated animation-shift uppercase link">На карте</a>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% set faq = global['restaurant-faq'][lang_code]|default(global['restaurant-faq']['ru']|default(null)) %}
    {% if faq %}
      {% set faqItems = [] %}
      {% if r.address is defined and faq.where is defined %}
        {% set addr = r.address.streetAddress|default('') ~ (r.address.addressLocality ? ', ' ~ r.address.addressLocality : '') %}
        {% set faqItems = faqItems|merge([{ title: faq.where, desc: addr, answerText: addr, icon: { src: url('data/img/ui/icons/icon-arrow-down-color-2.svg') } }]) %}
      {% endif %}
      {% if r.openingHours is defined and r.openingHours|length > 0 and faq.hours is defined %}
        {% set hoursText = [] %}
        {% for h in r.openingHours %}
          {% set hoursText = hoursText|merge([h.days|default('') ~ ' ' ~ h.hours|default('')]) %}
        {% endfor %}
        {% set hoursStr = hoursText|join('; ') %}
        {% set faqItems = faqItems|merge([{ title: faq.hours, desc: hoursStr, answerText: hoursStr, icon: { src: url('data/img/ui/icons/icon-arrow-down-color-2.svg') } }]) %}
      {% endif %}
      {% if r.servesCuisine is defined and faq.cuisine is defined %}
        {% set cuisineStr = r.servesCuisine|join(', ') %}
        {% set faqItems = faqItems|merge([{ title: faq.cuisine, desc: cuisineStr, answerText: cuisineStr, icon: { src: url('data/img/ui/icons/icon-arrow-down-color-2.svg') } }]) %}
      {% endif %}
      {% if r.telephone is defined and faq.contact is defined %}
        {% set telStr = r.telephone.title|default(r.telephone.href) %}
        {% set faqItems = faqItems|merge([{ title: faq.contact, desc: telStr, answerText: telStr, icon: { src: url('data/img/ui/icons/icon-arrow-down-color-2.svg') } }]) %}
      {% endif %}
      {% if r.priceRange is defined and faq.price is defined %}
        {% set faqItems = faqItems|merge([{ title: faq.price, desc: r.priceRange, answerText: r.priceRange, icon: { src: url('data/img/ui/icons/icon-arrow-down-color-2.svg') } }]) %}
      {% endif %}
      {% if faqItems|length > 0 %}
        <div class="container-md">
          <section class="restaurant-detail__item faq-wrap section">
            <div class="section__item heading-wrap">
              <h2 class="heading weight-400 uppercase">{{ faq.heading|default('FAQ') }}</h2>
            </div>
            <div class="section__item accordion-wrap">
              {% include 'components/accordion.twig' with { items: faqItems, accordion_id: 'restaurantFaq' } %}
            </div>
          </section>
        </div>
      {% endif %}
    {% endif %}

  </main>
  {% include 'sections/footer.twig' with {'data': {
    'background': { 'src': 'data/img/ui/bg3.webp' },
    'form': { 'heading': 'Получить консультацию' }
  }} %}
</div>
{% endblock %}

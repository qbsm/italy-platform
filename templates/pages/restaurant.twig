{% extends 'base.twig' %}

{% block content %}
<div id="page-content">
  {% include 'sections/header.twig' with {'data': {}} %}
  <main class="restaurant-detail" role="main">
    {% set r = restaurant.restaurant %}

    {% if restaurant.covers is defined and restaurant.covers|length > 0 %}
      <section class="restaurant-detail__item slider-wrap restaurant-intro">
        <div class="swiper-container" id="restaurantSlider" data-settings="{{ {
          loop: true,
          autoplay: { delay: 5000, disableOnInteraction: false },
          pagination: { enabled: true, clickable: true },
          navigation: { enabled: true },
          effect: 'fade',
          speed: 800
        }|json_encode }}">
          <div class="swiper-wrapper">
            {% for cover in restaurant.covers %}
              <div class="swiper-slide">
                <img src="{{ url(cover.src) }}" alt="{{ cover.alt|default(r.name) }}" class="img-responsive" loading="{{ loop.first ? 'eager' : 'lazy' }}">
              </div>
            {% endfor %}
          </div>
          <div class="swiper-pagination"></div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
        </div>

        <div class="restaurant-intro__overlay">
          <div class="container">
            <div class="restaurant-intro__content">
              <h1 class="restaurant-intro__title heading font-1 weight-300 uppercase">{{ r.name }}</h1>

              <div class="restaurant-intro__contacts">
                {% if r.address is defined %}
                  <p class="restaurant-intro__line">{{ r.address.addressLocality }}{% if r.address.streetAddress %}, {{ r.address.streetAddress }}{% endif %}</p>
                {% endif %}
                {% if r.telephone is defined %}
                  <a href="{{ r.telephone.href }}" class="restaurant-intro__line link">{{ r.telephone.title|default(r.telephone.href) }}</a>
                {% endif %}
              </div>

              {% if r.openingHours is defined and r.openingHours|length > 0 %}
                <div class="restaurant-intro__hours">
                  <div class="restaurant-intro__hours-title">
                    <span class="restaurant-intro__hours-icon" aria-hidden="true"></span>
                    <span>Часы работы:</span>
                  </div>
                  {% for h in r.openingHours %}
                    <div class="restaurant-intro__hours-row">{{ h.days }}: {{ h.hours }}</div>
                  {% endfor %}
                </div>
              {% endif %}

              {% if r.bookingPoint is defined or r.menuLink is defined %}
                <div class="restaurant-intro__actions">
                  {% if r.menuLink is defined and r.menuLink %}
                    <a href="{{ r.menuLink }}" target="_blank" rel="noopener noreferrer" class="button button-md button-rounded outline-color-1 color-1 uppercase link">Меню</a>
                  {% endif %}
                  {% if r.bookingPoint is defined and r.bookingPoint %}
                    <button type="button" class="button button-md button-rounded bg-color-1 color-2 uppercase link widget__point__{{ r.bookingPoint }}">Забронировать</button>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </section>
    {% endif %}

    {# ---- О ресторане: лого + текст + CTA + галерея ---- #}
    <section class="restaurant-detail__item about-wrap section">
      <div class="container-md">
        {% set aboutLogo = restaurant.logos is defined ? (restaurant.logos[0]|default(null)) : null %}
        {% if aboutLogo and aboutLogo.src %}
          <div class="section__item restaurant-about__logo">
            <img src="{{ url(aboutLogo.src) }}" alt="{{ aboutLogo.alt|default(r.name) }}"
                 style="height: {{ aboutLogo.height|default('6.5rem') }};" loading="lazy">
          </div>
        {% endif %}

        {% if restaurant.desc.short is defined %}
          <div class="section__item heading-wrap">
            <p class="restaurant-about__sub">{{ restaurant.desc.short }}</p>
          </div>
        {% endif %}

        {% if restaurant.desc is defined and restaurant.desc.full is defined %}
          {% set descParas = restaurant.desc.full is iterable ? restaurant.desc.full : [restaurant.desc.full] %}
          <div class="section__item desc-wrap">
            {% for para in descParas %}
              <p class="restaurant-about__col">{{ para }}</p>
            {% endfor %}
          </div>
        {% endif %}


        {% if restaurant.staff is defined and restaurant.staff|length > 0 %}
          <div class="section__item restaurant-about__staff">
            <h2 class="restaurant-staff__heading uppercase">Команда</h2>
            <ul class="restaurant-staff__list">
              {% for member in restaurant.staff %}
                <li class="restaurant-staff__item">
                  <span class="restaurant-staff__role">{{ member.role }}</span>
                  <span class="restaurant-staff__name">{{ member.name }}</span>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% set galleryItems = restaurant.gallery|default(restaurant.covers|default([])) %}
        {% if galleryItems|length > 0 %}
          <div class="section__item restaurant-about__gallery" id="restaurantGallery">
            {% for img in galleryItems %}
              <figure class="restaurant-about__photo">
                <a href="{{ url(img.src) }}" class="glightbox link" data-gallery="restaurant-gallery">
                  <img src="{{ url(img.src) }}" alt="{{ img.alt|default(r.name) }}" loading="lazy">
                </a>
              </figure>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </section>

  </main>
  {% include 'sections/footer.twig' with {'data': {
    'background': { 'src': 'data/img/ui/bg3.webp' },
    'form': { 'heading': 'Будьте в курсе' }
  }} %}
</div>

{% if r.bookingPoint is defined and r.bookingPoint %}
  <link rel="stylesheet" href="https://remarked.ru/widget/new/css/{{ r.bookingPoint }}.css">
  <script src="https://remarked.ru/widget/new/js/newidget-v2.js" defer></script>
  <script defer>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof widgetArea !== 'function') return;
      const points = [
        { name: 'Итали на Большом', phone: '+7 (812) 900-63-33', point: 600901 },
        { name: 'Итали в Виленском', phone: '+7 (812) 906-65-58', point: 910001 },
        { name: 'Итали на Московском', phone: '+7 (931) 954-61-97', point: 910005 },
        { name: 'Итали на Большой Морской', phone: '+7 (921) 944-03-00', point: 910006 },
        { name: 'ХИТЧ', phone: '+7 (921) 919-01-79', point: 910004 },
        { name: 'Гус Гус', phone: '+7 (911) 928-37-27', point: 910002 },
        { name: 'Bist', phone: '+7 (931) 994-75-15', point: 910007 }
      ];
      const current = points.find(p => p.point == {{ r.bookingPoint }});
      if (!current) return;
      const sortPoints = [current, ...points.filter(p => p.point !== current.point)];
      widgetArea({
        booking: sortPoints,
        button: '.widget__point__{{ r.bookingPoint }}',
        linkPolicy: '/policy/',
        newSlotsTime: true,
        requiredSelect: true,
        children: true,
        childrenQtyInput: true,
        childrenQtyMin: '0',
        childrenQtyMax: 10
      });
    });
  </script>
{% endif %}
{% endblock %}

{% set formId = 'formCallback' ~ random(1000000) %}
<form class="form-callback js-form-callback" novalidate method="post" action="" id="{{ formId }}">
  <div class="form-callback__container">
    <div class="form-callback__item form-callback-item-email">
      <input id="{{ formId }}Email" type="email" class="form-callback__input" name="email" inputmode="email" autocomplete="email" placeholder="{{ global['form-callback'].placeholder[lang_code].email }}" aria-required="true" aria-label="{{ global['form-callback'].label[lang_code].email }}">
    </div>
    <div class="form-callback__item form-callback-item-name">
      <input id="{{ formId }}Name" type="text" class="form-callback__input" name="name" autocomplete="name" placeholder="{{ global['form-callback'].placeholder[lang_code].name }}" aria-required="true" aria-label="{{ global['form-callback'].label[lang_code].name }}">
    </div>
    <div class="form-callback__item form-callback-item-city">
      <select id="{{ formId }}City" class="form-callback__input form-callback__select" name="city" required aria-required="true" aria-label="{{ global['form-callback'].label[lang_code].city }}">
        <option value="" disabled selected>{{ global['form-callback'].placeholder[lang_code].city }}</option>
        <option value="Санкт-Петербург">Санкт-Петербург</option>
        <option value="Москва">Москва</option>
      </select>
    </div>
    <div class="form-callback__item form-callback-item-policy">
      <label class="form-callback__custom-checkbox">
        <input id="{{ formId }}Policy" type="checkbox" name="policy" class="form-callback__checkbox" aria-required="true">
        <span class="form-callback__checkmark" aria-hidden="true"></span>
        <span class="form-callback__placeholder">{{ global['form-callback'].label[lang_code].policy }}</span>
      </label>
    </div>
    <div class="form-callback__item form-callback-item-hidden">
      <input type="hidden" name="current_url" value="">
      <input type="hidden" name="csrf_token" value="{{ csrf_token | default('') }}">
    </div>
    <div class="form-callback__item button-wrap">
      <button class="button button-sm bg-color-1 color-2 button-animated animation-shift link" type="submit">
        {% if data.button is defined and data.button.title is defined %}
          {{ data.button.title }}
        {% else %}
          {{ global['form-callback'].button[lang_code].title }}
        {% endif %}
      </button>
    </div>
    {% if global['form-callback'].rules[lang_code].policy is defined and global['form-callback'].rules[lang_code].policy %}
      <div class="form-callback__item form-callback-item-rules rules-wrap">
        <span class="form-callback__rules">{{ global['form-callback'].rules[lang_code].policy | raw }}</span>
      </div>
    {% endif %}
    <div class="form-callback__item form-callback__error hidden" aria-live="polite" aria-atomic="true">
      <span id="{{ formId }}Error" class="form-callback__error-text" role="alert" aria-live="assertive">{{ global['form-callback'].error[lang_code].title }}</span>
    </div>
  </div>
</form>

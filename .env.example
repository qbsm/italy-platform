# Application
APP_ENV=development
APP_DEBUG=1
APP_DEFAULT_LANG=ru
APP_BASE_URL=https://example.test/

# Почта (Symfony Mailer)
# DSN: smtp://user:pass@smtp.example.com:587  или  sendmail://default  или  native://default
MAILER_DSN=smtp://localhost:25
MAIL_TO=info@example.com
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="Экосистема итали"
MAIL_SUBJECT_PREFIX=[italy]

# Analytics (опционально)
# YANDEX_METRIC_ID=12345678
